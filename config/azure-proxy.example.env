# Public endpoint settings
PUBLIC_BASE_URL=https://llm.example.com/v1
PROXY_AUTH_MODE=api_key
PROXY_API_KEY=YOUR_API_KEY

# Azure placeholders
AZURE_RESOURCE_GROUP=YOUR_AZURE_RESOURCE_GROUP
AZURE_REGION=YOUR_AZURE_REGION
AZURE_RELAY_NAMESPACE=YOUR_AZURE_RELAY_NAMESPACE
HYBRID_CONNECTION_NAME=YOUR_HYBRID_CONNECTION_NAME

# Security controls
RATE_LIMIT_PER_MINUTE=60
MAX_REQUEST_BYTES=1048576
